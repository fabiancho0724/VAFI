rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return request.auth.token.email_verified == true; }

    function isValidUserPublic(data) {
      return data.keys().hasAll(['displayName', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 4
        && data.displayName is string
        && data.displayName.size() <= 100
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidUserPrivate(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 4
        && data.email is string
        && data.email.size() <= 150
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Dummy block for linter although users shouldn't be scraping others
      allow create: if isSignedIn() && isVerified() && request.auth.uid == userId 
        && isValidUserPublic(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isVerified() && request.auth.uid == userId 
        && isValidUserPublic(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
      
      match /private/info {
        allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        // no list allowed for private info directly
        allow create: if isSignedIn() && isVerified() && request.auth.uid == userId
          && isValidUserPrivate(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
        allow update: if isSignedIn() && isVerified() && request.auth.uid == userId
          && isValidUserPrivate(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time
          && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'updatedAt']);
      }
    }
  }
}
